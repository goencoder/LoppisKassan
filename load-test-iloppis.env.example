# Example configuration for iLoppis load test
# Run with: make load-test ENV=./load-test-iloppis.env

# IMPORTANT: You must first create market infrastructure using setup-test:
# 1. Copy load-test-setup.env.example to load-test-setup.env
# 2. Run: make setup-test ENV=./load-test-setup.env
# 3. Copy EVENT_ID and API_KEY from setup output to this file

MODE=ILOPPIS
API_BASE_URL=https://iloppis-staging.fly.dev

# Event ID and API key from setup-test output
EVENT_ID=REPLACE_WITH_EVENT_ID_FROM_SETUP
API_KEY=REPLACE_WITH_API_KEY_FROM_SETUP

# Or use cashier code instead of API_KEY:
# CASHIER_CODE=XXX-XXX

# Load test parameters
TARGET_TOTAL=500000
SELLER_COUNT=100
MIN_PRICE=10
MAX_PRICE=1000
MIN_ITEMS_PER_PURCHASE=10
MAX_ITEMS_PER_PURCHASE=20
