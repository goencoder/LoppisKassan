# Setup configuration for creating complete market infrastructure from scratch
# Run with: make setup-test ENV=./load-test-setup.env

# API endpoints
API_BASE_URL=http://localhost:8080
MAILHOG_URL=http://localhost:8025

# User accounts
# First user to login becomes platform owner automatically
PLATFORM_OWNER_EMAIL=goran@goencoder.se
MARKET_OWNER_EMAIL=peter.karlsson@sillstugan.se

# Market and event details
MARKET_NAME="Load Test Market"
EVENT_NAME="Load Test Event"

# Number of vendors to create and approve
VENDOR_COUNT=100
